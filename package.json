{
  "name": "claude-cli-terminal",
  "version": "4.7.19",
  "description": "멀티 프로젝트 Claude CLI 터미널 - 시스템에 설치된 claude 명령어를 터미널 에뮬레이터로 구동",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "postinstall": "electron-rebuild -f -w node-pty",
    "rebuild": "electron-rebuild -f -w node-pty",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "deploy": "bash deploy.sh",
    "deploy:patch": "bash deploy.sh patch",
    "deploy:minor": "bash deploy.sh minor",
    "deploy:major": "bash deploy.sh major"
  },
  "build": {
    "appId": "com.claude-cli-terminal.app",
    "productName": "Claude CLI Terminal",
    "artifactName": "Claude-CLI-Terminal-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "effecdi",
      "repo": "auto-teminel"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "**/*",
      "!node_modules/node-pty/build/Release/.forge-meta"
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.4.5",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "express": "^4.21.0",
    "node-pty": "^1.0.0",
    "ws": "^8.17.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9"
  },
  "keywords": [
    "claude",
    "cli",
    "terminal",
    "electron",
    "multi-project"
  ],
  "author": "",
  "license": "MIT"
}
